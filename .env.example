# Feature flags — set to "true" when ready to launch (requires rebuild/redeploy)
# Copy to .env for local testing: cp .env.example .env

VITE_FEATURE_NEATCLOCK_PRINTS=false
VITE_FEATURE_LOCKSCREEN_GOODIES=false
VITE_FEATURE_PREMIUM_THEMES=false
VITE_FEATURE_SPONSOR_FOOTER=false
VITE_FEATURE_AFFILIATE_LINKS=false

# Optional config when flags are enabled
# VITE_PRINTS_SHOP_URL=https://shop.example.com/neatclock-prints
# VITE_LOCKSCREEN_URL=https://cdn.example.com/lockscreen.jpg
# VITE_SPONSOR_NAME=Minimalist Notebook Co.
# VITE_SPONSOR_TAGLINE=analogue tools for organized minds
# Interest / greenlight form (Formspree or FormSubmit — see WAITLIST.md)
VITE_INTEREST_FORM_ENDPOINT=
# Fastest path: your inbox only — no Formspree account (builds formsubmit.co/ajax URL)
# VITE_INTEREST_FORM_EMAIL=you@example.com

# Legacy alias — falls back if INTEREST_FORM_ENDPOINT unset
# VITE_WAITLIST_URL=

# Privacy-friendly analytics (Plausible) — set domain when live; skipped on localhost
# VITE_PLAUSIBLE_DOMAIN=neatclock.app
